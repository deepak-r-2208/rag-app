# Local Postgres. If you're using docker-compose, this is overridden by the
# `environment:` block in docker-compose.yml (points at the `db` service) —
# this value only matters if you run the backend outside Docker.
DATABASE_URL=postgresql://postgres:12345@localhost:5432/postgres

# Generate a real secret with: openssl rand -hex 32
JWT_SECRET=d364212c1367f385a4fe43f03ac5e6fc
JWT_EXPIRY_HOURS=168

# Local Ollama. Same override note as DATABASE_URL — docker-compose points
# this at the `ollama` service automatically.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b

# Your frontend origin(s), comma-separated.
CORS_ORIGINS=http://localhost:5173

TOP_K=5
MIN_RELEVANCE_SCORE=0.08
